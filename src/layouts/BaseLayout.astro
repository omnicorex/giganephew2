---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = 'Giganephew — In-Home Tech Support',
  description = 'Expert in-home tech support for your computers, smartphones, smart home, and more. Serving families and individuals with 25+ years of experience.',
  ogImage = '/og-image.png',
  noIndex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://giganephew.com');
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- Accessibility: skip to main content -->
    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- Fixed ambient glow — above all compositor layers via mix-blend-mode: screen.
         Screen-blending a low-opacity teal is invisible on text/cards (dark bg barely
         changes) but fills dark voids with ambient color, bypassing GPU layer isolation. -->
    <div
      class="fixed pointer-events-none"
      style="top: -35%; right: -25%; width: 90vw; height: 90vw; z-index: 60; mix-blend-mode: screen; background: radial-gradient(ellipse at center, rgba(34,211,238,0.09) 0%, rgba(34,211,238,0.04) 35%, rgba(34,211,238,0.01) 60%, transparent 75%)"
      aria-hidden="true"
    ></div>

    <Header />

    <main id="main-content" style="position: relative; z-index: 1;">
      <slot />
    </main>

    <Footer />

    <!-- Scroll reveal: IntersectionObserver -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
