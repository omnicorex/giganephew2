---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — Giganephew"
  description="This page doesn't exist. Let's get you back on track."
  noIndex={true}
>
  <section class="min-h-[100dvh] flex items-center justify-center px-6 relative overflow-hidden">

    <div class="flex flex-col items-center text-center gap-8 max-w-sm relative z-10">

      <!-- 3D logo — large, with teal glow behind it -->
      <div class="relative reveal">
        <!-- Glow behind the logo -->
        <div
          class="absolute inset-0 pointer-events-none"
          style="background: radial-gradient(ellipse at center, rgba(34,211,238,0.18) 0%, transparent 70%); transform: scale(1.4); filter: blur(24px);"
          aria-hidden="true"
        ></div>
        <img
          src="/giganephew-logo3d.png"
          alt="Giganephew"
          class="relative w-44 h-44 object-contain drop-shadow-[0_0_32px_rgba(34,211,238,0.3)]"
          loading="eager"
        />
      </div>

      <!-- Copy -->
      <div class="flex flex-col gap-3 reveal" style="transition-delay: 80ms">
        <p class="eyebrow">404</p>
        <h1 class="heading-2 text-[#F0EFEB]">Wrong turn.</h1>
        <p class="text-[#8A8A96] leading-relaxed text-sm">
          This page doesn't exist — but we can get you back on track.
          Even the best tech people take a wrong turn sometimes.
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap items-center justify-center gap-3 reveal" style="transition-delay: 160ms">
        <a
          href="/"
          class="group inline-flex items-center gap-2 pl-5 pr-2 py-2.5 rounded-full
                 bg-[#22D3EE] text-[#0C0C0E] font-semibold text-sm
                 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]
                 hover:bg-[#38bdf8] active:scale-[0.98]"
        >
          Go home
          <span class="w-7 h-7 rounded-full bg-black/15 flex items-center justify-center
                       transition-transform duration-300
                       group-hover:translate-x-0.5 group-hover:-translate-y-px">
            <svg width="13" height="13" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>

        <a
          href="/services"
          class="inline-flex items-center px-5 py-2.5 rounded-full text-sm font-medium
                 border border-white/10 text-[#8A8A96]
                 hover:text-[#F0EFEB] hover:border-white/20
                 transition-all duration-300"
        >
          Browse services
        </a>
      </div>

    </div>
  </section>
</BaseLayout>
