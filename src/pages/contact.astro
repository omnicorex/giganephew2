---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Giganephew In-Home Tech Support"
  description="Book a home tech support visit or ask a question. We respond within one business day."
>

  <!-- Hero -->
  <section class="pt-40 pb-16 px-6 relative overflow-hidden">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[60vw] h-[50vh] pointer-events-none"
      style="background: radial-gradient(ellipse at 50% 0%, rgba(34,211,238,0.06) 0%, transparent 70%)"
      aria-hidden="true"
    ></div>
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_560px] gap-16 items-start">

        <!-- Left: info -->
        <div class="flex flex-col gap-6 reveal">
          <span class="eyebrow">Get in touch</span>
          <h1 class="heading-1 text-[#F0EFEB]">
            Tell us what's going on.
          </h1>
          <p class="text-[#8A8A96] leading-relaxed max-w-sm">
            Fill out the form and we'll get back to you within one business day to
            confirm your visit and answer any questions.
          </p>

          <!-- Info cards -->
          <div class="flex flex-col gap-3 mt-4">
            <div class="flex items-start gap-3 p-4 rounded-xl bg-white/[0.03] border border-white/[0.06]">
              <div class="w-8 h-8 rounded-lg bg-[rgba(34,211,238,0.08)] flex items-center justify-center text-[#22D3EE] shrink-0">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 8v4l3 3"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-[#F0EFEB]">Response time</p>
                <p class="text-xs text-[#8A8A96] mt-0.5">Within one business day</p>
              </div>
            </div>

            <div class="flex items-start gap-3 p-4 rounded-xl bg-white/[0.03] border border-white/[0.06]">
              <div class="w-8 h-8 rounded-lg bg-[rgba(34,211,238,0.08)] flex items-center justify-center text-[#22D3EE] shrink-0">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                  <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-[#F0EFEB]">In-home visits</p>
                <p class="text-xs text-[#8A8A96] mt-0.5">We come to you — no drop-off needed</p>
              </div>
            </div>

            <div class="flex items-start gap-3 p-4 rounded-xl bg-white/[0.03] border border-white/[0.06]">
              <div class="w-8 h-8 rounded-lg bg-[rgba(34,211,238,0.08)] flex items-center justify-center text-[#22D3EE] shrink-0">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-[#F0EFEB]">Availability</p>
                <p class="text-xs text-[#8A8A96] mt-0.5">Same-week scheduling in most areas</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: form iframe -->
        <div class="card-bezel reveal" style="transition-delay: 120ms">
          <div class="card-inner overflow-hidden">
            <iframe
              src="https://forms.omnicorex.com/forms/contact1-fsclej"
              title="Giganephew contact form"
              width="100%"
              height="680"
              style="border: none; display: block; background: transparent;"
              loading="lazy"
            ></iframe>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
