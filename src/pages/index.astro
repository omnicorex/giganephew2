---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    id: 'computer',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    title: 'Computer & Laptop Care',
    desc: 'Slow computer, virus removal, software issues, printers. We make it fast and reliable again.',
    span: 'md:col-span-2',
  },
  {
    id: 'setup',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'New Device Setup',
    desc: 'Got something new? We set it up completely — transfer your data, configure accounts, install your apps.',
    span: '',
  },
  {
    id: 'smartphone',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>`,
    title: 'Smartphone & Tablet Help',
    desc: 'iPhone or Android — syncing, storage, apps, and everything in between.',
    span: '',
  },
  {
    id: 'wifi',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor" stroke="none"/></svg>`,
    title: 'Home Wi-Fi & Networking',
    desc: 'Dead zones, dropped connections, slow speeds. We diagnose and fix your entire home network.',
    span: '',
  },
  {
    id: 'smarthome',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Smart Home & Entertainment',
    desc: 'Smart TVs, streaming, Alexa, Ring, Nest. Your smart home, fully working the way it should.',
    span: '',
  },
  {
    id: 'safety',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Online Safety & Scam Protection',
    desc: 'Security health checkup, scam coaching, password management, and privacy settings — for real peace of mind.',
    span: 'md:col-span-2',
  },
];

const stats = [
  { value: '25+', label: 'Years of experience' },
  { value: '6', label: 'Service categories' },
  { value: '1', label: 'Visit away' },
];
---

<BaseLayout>

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="relative min-h-[100dvh] flex items-center pt-24 pb-16">


    <div class="max-w-6xl mx-auto px-6 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_480px] gap-12 lg:gap-6 items-center">

        <!-- Left: Copy -->
        <div class="flex flex-col gap-6 reveal">
          <span class="eyebrow w-fit px-3 py-1.5 rounded-full bg-[rgba(34,211,238,0.08)] border border-[rgba(34,211,238,0.2)]">
            In-home tech support
          </span>

          <h1 class="display text-[#F0EFEB]">
            Tech help that<br />
            <em class="not-italic text-[#22D3EE]">comes to you.</em>
          </h1>

          <p class="text-lg text-[#8A8A96] leading-relaxed max-w-md">
            Computers, smartphones, Wi-Fi, smart home — whatever's giving you trouble,
            we come to your home and sort it out. No jargon, no judgment.
          </p>

          <div class="flex flex-wrap items-center gap-3 pt-2">
            <!-- Primary CTA -->
            <a
              href="/contact"
              class="group inline-flex items-center gap-2 pl-5 pr-2 py-2.5 rounded-full
                     bg-[#22D3EE] text-[#0C0C0E]
                     font-semibold text-sm
                     transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]
                     hover:bg-[#38bdf8] active:scale-[0.98]"
            >
              Book a visit
              <span class="w-7 h-7 rounded-full bg-black/15 flex items-center justify-center
                           transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]
                           group-hover:translate-x-0.5 group-hover:-translate-y-px">
                <svg width="13" height="13" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>

            <!-- Secondary -->
            <a
              href="/services"
              class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full
                     border border-white/10 text-sm font-medium text-[#8A8A96]
                     hover:text-[#F0EFEB] hover:border-white/20
                     transition-all duration-300"
            >
              See all services
            </a>
          </div>

          <!-- Stats row -->
          <div class="flex gap-8 pt-4 border-t border-white/8 mt-2">
            {stats.map((s) => (
              <div class="flex flex-col">
                <span class="text-2xl font-bold text-[#F0EFEB] tracking-tight">{s.value}</span>
                <span class="text-xs text-[#8A8A96] mt-0.5">{s.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: 3D hero image (GIGANEPHEW text + character) -->
        <div class="relative flex items-center justify-center reveal" style="transition-delay: 150ms">
          <img
            src="/giganephew2-hero2.png"
            alt="Giganephew — Your Personal Tech Assistant for the Home"
            class="w-full h-auto object-contain max-h-[440px]"
            loading="eager"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ── Services ──────────────────────────────────────────────────────── -->
  <section class="py-28 px-6" id="services" aria-labelledby="services-heading">
    <div class="max-w-6xl mx-auto">

      <div class="flex flex-col gap-3 mb-14 reveal">
        <span class="eyebrow">What we do</span>
        <h2 class="heading-1 text-[#F0EFEB] max-w-lg" id="services-heading">
          Every tech problem, handled.
        </h2>
        <p class="text-[#8A8A96] max-w-md leading-relaxed">
          From a slow laptop to a full smart home setup — we cover it all, in your home, on your schedule.
        </p>
      </div>

      <!-- Asymmetric bento grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 reveal-group">
        {services.map((service) => (
          <a
            href={`/services#${service.id}`}
            class={`card-bezel group cursor-pointer
                    transition-all duration-400 ease-[cubic-bezier(0.32,0.72,0,1)]
                    hover:border-[rgba(34,211,238,0.2)]
                    reveal ${service.span}`}
          >
            <div class="card-inner p-6 flex flex-col gap-4 h-full
                        transition-colors duration-300
                        group-hover:bg-[#1C1C22]">
              <!-- Icon -->
              <div class="w-10 h-10 rounded-xl bg-[rgba(34,211,238,0.08)] text-[#22D3EE]
                          flex items-center justify-center
                          transition-colors duration-300
                          group-hover:bg-[rgba(34,211,238,0.15)]">
                <Fragment set:html={service.icon} />
              </div>

              <div class="flex flex-col gap-1.5 flex-1">
                <h3 class="font-semibold text-[#F0EFEB] text-base leading-snug">
                  {service.title}
                </h3>
                <p class="text-sm text-[#8A8A96] leading-relaxed">
                  {service.desc}
                </p>
              </div>

              <!-- Arrow link indicator -->
              <div class="flex items-center gap-1 text-xs font-medium text-[#22D3EE]
                          opacity-0 group-hover:opacity-100
                          translate-x-[-4px] group-hover:translate-x-0
                          transition-all duration-300">
                Learn more
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 text-center reveal">
        <a
          href="/services"
          class="inline-flex items-center gap-1.5 text-sm text-[#8A8A96]
                 hover:text-[#22D3EE] transition-colors duration-300"
        >
          View full service catalog
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── About teaser ───────────────────────────────────────────────────── -->
  <section class="py-28 px-6 border-t border-white/8" aria-labelledby="about-heading">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Left: copy -->
        <div class="flex flex-col gap-6 reveal">
          <span class="eyebrow">Who we are</span>
          <h2 class="heading-1 text-[#F0EFEB]" id="about-heading">
            A real person.<br />Not a call center.
          </h2>
          <p class="text-[#8A8A96] leading-relaxed">
            Giganephew was founded by Aram, a tech professional with over 25 years of experience.
            The idea was simple: most people don't need enterprise IT — they need someone patient,
            knowledgeable, and willing to sit down with them at their kitchen table.
          </p>
          <p class="text-[#8A8A96] leading-relaxed">
            Every visit is one-on-one. No rotating technicians, no scripts. Just straightforward
            help from someone who genuinely enjoys making technology work for people.
          </p>
          <a
            href="/about"
            class="group inline-flex items-center gap-2 text-sm font-semibold text-[#22D3EE]
                   hover:text-[#38bdf8] transition-colors duration-300 w-fit mt-2"
          >
            More about Giganephew
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-0.5">
              <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Right: accent card -->
        <div class="card-bezel reveal" style="transition-delay: 120ms">
          <div class="card-inner p-8 flex flex-col gap-6">
            <div
              class="w-12 h-12 rounded-2xl flex items-center justify-center text-[#22D3EE]"
              style="background: rgba(34,211,238,0.08)"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <blockquote class="text-[#F0EFEB] text-lg font-medium leading-relaxed">
              "Technology should make your life easier — not give you a headache.
              My job is to make that actually true, in your home."
            </blockquote>
            <footer class="flex flex-col gap-0.5">
              <span class="text-sm font-semibold text-[#F0EFEB]">Aram</span>
              <span class="text-xs text-[#8A8A96]">Founder, Giganephew</span>
            </footer>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CTA Banner ─────────────────────────────────────────────────────── -->
  <section class="py-28 px-6" aria-labelledby="cta-heading">
    <div class="max-w-6xl mx-auto">
      <div class="card-bezel reveal">
        <div
          class="card-inner px-8 py-16 text-center flex flex-col items-center gap-6 relative overflow-hidden"
          style="background: linear-gradient(135deg, #141418 0%, #1a1a22 100%)"
        >
          <!-- Background glow -->
          <div
            class="absolute inset-0 pointer-events-none"
            style="background: radial-gradient(ellipse at 50% 100%, rgba(34,211,238,0.08) 0%, transparent 65%)"
            aria-hidden="true"
          ></div>

          <span class="eyebrow relative z-10">Ready to get started?</span>
          <h2 class="heading-1 text-[#F0EFEB] relative z-10 max-w-xl" id="cta-heading">
            Let's fix it — at your place.
          </h2>
          <p class="text-[#8A8A96] max-w-md leading-relaxed relative z-10">
            Tell us what's going on and we'll come to you. Same-week availability in most areas.
          </p>

          <a
            href="/contact"
            class="group relative z-10 inline-flex items-center gap-2 pl-6 pr-2 py-3 rounded-full
                   bg-[#22D3EE] text-[#0C0C0E]
                   font-semibold text-sm
                   transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]
                   hover:bg-[#38bdf8] active:scale-[0.98]
                   shadow-[0_0_32px_rgba(34,211,238,0.25)]"
          >
            Book a visit
            <span class="w-8 h-8 rounded-full bg-black/15 flex items-center justify-center
                         transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]
                         group-hover:translate-x-0.5 group-hover:-translate-y-px">
              <svg width="13" height="13" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
