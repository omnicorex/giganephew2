---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    id: 'computer',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    title: 'Computer & Laptop Care',
    desc: 'Slow computer, virus removal, software issues, printers. We make it fast and reliable again.',
  },
  {
    id: 'setup',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'New Device Setup',
    desc: 'Got something new? We set it up completely — transfer your data, configure accounts, install your apps.',
  },
  {
    id: 'smartphone',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>`,
    title: 'Smartphone & Tablet Help',
    desc: 'iPhone or Android — syncing, storage, apps, and everything in between.',
  },
  {
    id: 'wifi',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor" stroke="none"/></svg>`,
    title: 'Home Wi-Fi & Networking',
    desc: 'Dead zones, dropped connections, slow speeds. We diagnose and fix your entire home network.',
  },
  {
    id: 'smarthome',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Smart Home & Entertainment',
    desc: 'Smart TVs, streaming, Alexa, Ring, Nest. Your smart home, fully working the way it should.',
  },
  {
    id: 'safety',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Online Safety & Scam Protection',
    desc: 'Security health checkup, scam coaching, password management, and privacy settings — for real peace of mind.',
  },
];

const stats = [
  { value: '25+', label: 'Years of experience' },
  { value: '6', label: 'Service categories' },
  { value: '1', label: 'Visit away' },
];
---

<BaseLayout>

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="relative min-h-[100dvh] flex items-center pt-24 pb-16">

    <div class="max-w-6xl mx-auto px-6 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_480px] gap-12 lg:gap-6 items-center">

        <!-- Left: Copy -->
        <div class="flex flex-col gap-6 reveal">
          <span class="eyebrow w-fit px-3 py-1.5 rounded-full bg-[rgba(34,211,238,0.08)] border border-[rgba(34,211,238,0.2)]">
            In-home tech support
          </span>

          <h1 class="display text-[#F0EFEB]">
            Tech help that<br />
            <em class="not-italic text-[#22D3EE]">comes to you.</em>
          </h1>

          <p class="text-lg text-[#8A8A96] leading-relaxed max-w-md">
            Computers, smartphones, Wi-Fi, smart home — whatever's giving you trouble,
            we come to your home and sort it out. No jargon, no judgment.
          </p>

          <div class="flex flex-wrap items-center gap-3 pt-2">
            <a
              href="/contact"
              class="group inline-flex items-center gap-2 pl-5 pr-2 py-2.5 rounded-full
                     bg-[#22D3EE] text-[#0C0C0E] font-semibold text-sm
                     transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]
                     hover:bg-[#38bdf8] active:scale-[0.98]"
            >
              Book a visit
              <span class="w-7 h-7 rounded-full bg-black/15 flex items-center justify-center
                           transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]
                           group-hover:translate-x-0.5 group-hover:-translate-y-px">
                <svg width="13" height="13" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
            <a
              href="/services"
              class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full
                     border border-white/10 text-sm font-medium text-[#8A8A96]
                     hover:text-[#F0EFEB] hover:border-white/20 transition-all duration-300"
            >
              See all services
            </a>
          </div>

          <!-- Stats row -->
          <div class="flex gap-8 pt-4 border-t border-white/8 mt-2">
            {stats.map((s) => (
              <div class="flex flex-col">
                <span class="text-2xl font-bold text-[#F0EFEB] tracking-tight">{s.value}</span>
                <span class="text-xs text-[#8A8A96] mt-0.5">{s.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: 3D hero image -->
        <div class="relative flex items-center justify-center reveal" style="transition-delay: 150ms">
          <img
            src="/giganephew2-hero2.png"
            alt="Giganephew — Your Personal Tech Assistant for the Home"
            class="w-full h-auto object-contain max-h-[440px]"
            loading="eager"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ── Services Conveyor ─────────────────────────────────────────────── -->
  <div id="conveyor-wrapper" style="height: 600vh;">
    <div id="conveyor-sticky" class="sticky top-0" style="height: 100dvh;">

      <div id="conveyor-inner">

        <!-- Info panel -->
        <div id="conveyor-info">
          <span class="eyebrow conveyor-eyebrow">What we do</span>
          <h2 class="text-[#F0EFEB] conveyor-heading" id="services-heading">
            Every tech<br/>problem,<br class="conveyor-br-desktop"/>handled.
          </h2>
          <p class="text-sm text-[#8A8A96] leading-relaxed conveyor-desc">
            We come to your home and sort it out — no jargon, no shipping, no waiting.
          </p>

          <!-- Counter + dots — row on mobile, stacked on desktop -->
          <div id="conveyor-counter-group">
            <div class="flex items-baseline gap-2">
              <span id="conveyor-counter"
                    class="text-3xl font-bold text-[#F0EFEB] tracking-tight"
                    style="font-variant-numeric: tabular-nums;">01</span>
              <span class="text-[#8A8A96] text-sm font-medium">/ 06</span>
            </div>
            <div class="flex items-center gap-2">
              {services.map((s, i) => (
                <div
                  class="conveyor-dot h-1.5 rounded-full"
                  style={i === 0
                    ? 'width:24px; background:#22D3EE; border-radius:3px; transition: all 0.4s cubic-bezier(0.32,0.72,0,1);'
                    : 'width:6px; background:rgba(255,255,255,0.18); border-radius:50%; transition: all 0.4s cubic-bezier(0.32,0.72,0,1);'}
                  aria-hidden="true"
                ></div>
              ))}
            </div>
          </div>

          <!-- CTA — mobile: compact text link -->
          <a
            href="/services"
            class="conveyor-cta-mobile inline-flex items-center gap-1.5 text-xs font-semibold
                   text-[#8A8A96] hover:text-[#22D3EE] transition-colors duration-300"
          >
            Explore all services
            <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <!-- CTA — desktop: pill button -->
          <a
            href="/services"
            class="conveyor-cta group inline-flex items-center gap-2 pl-5 pr-2 py-2.5 rounded-full w-fit
                   bg-white/5 border border-white/10 text-sm font-medium text-[#8A8A96]
                   hover:text-[#F0EFEB] hover:border-white/20
                   transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] active:scale-[0.98]"
          >
            Explore all services
            <span class="w-7 h-7 rounded-full bg-white/8 flex items-center justify-center
                         transition-transform duration-300
                         group-hover:translate-x-0.5 group-hover:-translate-y-px">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>

        <!-- Card conveyor viewport — mask-image fades cards at edges so the
             page background (incl. ambient glow) shows through seamlessly.
             clip-path clips the track without forcing a GPU compositor layer. -->
        <div id="conveyor-viewport" class="relative">

          <!-- Card track — JS drives translateY -->
          <div id="cards-track" class="absolute w-full">
            {services.map((service, i) => (
              <a
                href={`/services#${service.id}`}
                class="service-card card-bezel block"
                data-index={String(i)}
                style="margin-bottom: 16px; transition: opacity 0.5s cubic-bezier(0.32,0.72,0,1), transform 0.5s cubic-bezier(0.32,0.72,0,1);"
              >
                <div class="card-inner service-card-inner flex items-center gap-5 px-5 md:px-7">
                  <!-- Icon -->
                  <div class="shrink-0 service-card-icon rounded-2xl flex items-center justify-center text-[#22D3EE]"
                       style="background: rgba(34,211,238,0.08);">
                    <Fragment set:html={service.icon} />
                  </div>
                  <!-- Text -->
                  <div class="flex flex-col gap-1.5 flex-1 min-w-0">
                    <h3 class="font-bold text-[#F0EFEB] leading-snug service-card-title">{service.title}</h3>
                    <p class="text-[#8A8A96] leading-relaxed service-card-desc">{service.desc}</p>
                  </div>
                  <!-- Arrow -->
                  <svg class="shrink-0 text-[#22D3EE] opacity-40" width="16" height="16" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </a>
            ))}
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- Conveyor responsive CSS -->
  <style>
    /* ── Mobile-first base ── */
    #conveyor-inner {
      display: flex;
      flex-direction: column;
      height: 100%;
      max-width: 72rem;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    #conveyor-info {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      padding-top: 4.5rem; /* clear fixed nav (~60px pill + breathing room) */
      padding-bottom: 0.5rem;
      flex-shrink: 0;
    }

    /* Hide desktop-only elements on mobile */
    .conveyor-desc,
    .conveyor-cta,
    .conveyor-eyebrow {
      display: none;
    }

    /* Mobile CTA: compact text link — visible on mobile */
    .conveyor-cta-mobile {
      display: inline-flex;
      margin-top: 0.1rem;
    }

    /* Mobile heading: compact */
    .conveyor-heading {
      font-size: 1.15rem;
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    /* Desktop br tag hidden on mobile */
    .conveyor-br-desktop {
      display: none;
    }

    /* Counter font smaller on mobile */
    #conveyor-counter {
      font-size: 1.5rem;
    }

    /* Counter + dots: horizontal row on mobile */
    #conveyor-counter-group {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 0.25rem;
    }

    /* Viewport: takes all remaining height on mobile.
       clip-path clips the track without creating an opaque GPU layer.
       mask-image fades cards at edges so the ambient glow shows through. */
    #conveyor-viewport {
      flex: 1;
      min-height: 0;
      clip-path: inset(0);
      -webkit-mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        black 28%,
        black 72%,
        transparent 100%
      );
      mask-image: linear-gradient(
        to bottom,
        transparent 0%,
        black 28%,
        black 72%,
        transparent 100%
      );
    }

    /* Card inner height — mobile */
    .service-card-inner {
      height: 120px;
    }

    .service-card-icon {
      width: 2.75rem;
      height: 2.75rem;
    }

    .service-card-title {
      font-size: 0.875rem;
    }

    .service-card-desc {
      font-size: 0.72rem;
    }


    /* ── Desktop overrides (md: 768px+) ── */
    @media (min-width: 768px) {
      #conveyor-inner {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 4rem;
        align-items: center;
      }

      #conveyor-info {
        gap: 1.5rem;
        padding-top: 0;
        padding-bottom: 0;
      }

      .conveyor-desc {
        display: block;
      }

      .conveyor-cta {
        display: inline-flex;
      }

      .conveyor-cta-mobile {
        display: none;
      }

      .conveyor-eyebrow {
        display: block;
      }

      .conveyor-heading {
        font-size: clamp(2rem, 4.5vw, 3.5rem);
        line-height: 1.1;
        letter-spacing: -0.025em;
      }

      .conveyor-br-desktop {
        display: block;
      }

      #conveyor-counter {
        font-size: 1.875rem; /* text-3xl */
      }

      #conveyor-counter-group {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.75rem;
        margin-top: 0;
      }

      #conveyor-viewport {
        flex: none;
        height: 100dvh;
        clip-path: inset(0);
        -webkit-mask-image: linear-gradient(
          to bottom,
          transparent 0%,
          black 22%,
          black 78%,
          transparent 100%
        );
        mask-image: linear-gradient(
          to bottom,
          transparent 0%,
          black 22%,
          black 78%,
          transparent 100%
        );
      }

      .service-card-inner {
        height: 200px;
      }

      .service-card-icon {
        width: 3.5rem;
        height: 3.5rem;
      }

      .service-card-title {
        font-size: 1.125rem;
      }

      .service-card-desc {
        font-size: 0.875rem;
      }

    }
  </style>

  <!-- Conveyor JS — rAF-throttled, GPU-only transforms, dynamic card height -->
  <script>
  (function () {
    const wrapper  = document.getElementById('conveyor-wrapper') as HTMLElement | null;
    const track    = document.getElementById('cards-track') as HTMLElement | null;
    if (!wrapper || !track) return;

    const cards   = Array.from(track.querySelectorAll<HTMLElement>('.service-card'));
    const dots    = Array.from(document.querySelectorAll<HTMLElement>('.conveyor-dot'));
    const counter = document.getElementById('conveyor-counter') as HTMLElement | null;
    const vpEl    = document.getElementById('conveyor-viewport') as HTMLElement | null;
    const TOTAL   = cards.length;
    const GAP     = 16;

    let current = -1;

    function getCardH(): number {
      return cards[0]?.offsetHeight ?? 120;
    }

    function setActive(idx: number) {
      const CARD_H  = getCardH();
      const STEP    = CARD_H + GAP;
      // Center within the card viewport — uses offsetHeight so it's accurate
      // on both mobile (viewport = flex:1 below info strip) and desktop (100dvh).
      const vpH     = vpEl?.offsetHeight ?? window.innerHeight;
      const centerY = vpH / 2 - CARD_H / 2;

      if (idx === current) return;
      current = idx;

      // Translate track so active card is vertically centered in the viewport
      track!.style.transform = `translateY(${centerY - idx * STEP}px)`;

      // Opacity + scale per card based on distance from active
      cards.forEach((card, i) => {
        const dist = Math.abs(i - idx);
        if (dist === 0) {
          card.style.opacity = '1';
          card.style.transform = 'scale(1)';
        } else if (dist === 1) {
          card.style.opacity = '0.28';
          card.style.transform = 'scale(0.91)';
        } else {
          card.style.opacity = '0.07';
          card.style.transform = 'scale(0.82)';
        }
      });

      // Pill progress dots
      dots.forEach((dot, i) => {
        if (i === idx) {
          dot.style.width = '24px';
          dot.style.background = '#22D3EE';
          dot.style.borderRadius = '3px';
        } else {
          dot.style.width = '6px';
          dot.style.background = 'rgba(255,255,255,0.18)';
          dot.style.borderRadius = '50%';
        }
      });

      // Counter
      if (counter) counter.textContent = String(idx + 1).padStart(2, '0');
    }

    function update() {
      const rect       = wrapper!.getBoundingClientRect();
      const scrolled   = -rect.top;
      const scrollable = rect.height - window.innerHeight;
      const progress   = Math.max(0, Math.min(1, scrolled / scrollable));
      setActive(Math.round(progress * (TOTAL - 1)));
    }

    setActive(0);
    requestAnimationFrame(() => {
      track.style.transition = 'transform 0.55s cubic-bezier(0.32, 0.72, 0, 1)';
    });

    // Apply will-change only while scrolling, release after idle — prevents
    // the viewport's overflow:hidden from being permanently promoted to a
    // GPU compositor layer that blocks the fixed ambient glow.
    let ticking = false;
    let idleTimer: ReturnType<typeof setTimeout> | null = null;
    window.addEventListener('scroll', () => {
      if (idleTimer) clearTimeout(idleTimer);
      if (track) track.style.willChange = 'transform';
      cards.forEach(c => { c.style.willChange = 'transform, opacity'; });

      if (!ticking) {
        requestAnimationFrame(() => { update(); ticking = false; });
        ticking = true;
      }

      idleTimer = setTimeout(() => {
        if (track) track.style.willChange = 'auto';
        cards.forEach(c => { c.style.willChange = 'auto'; });
      }, 200);
    }, { passive: true });

    window.addEventListener('resize', () => {
      current = -1; // force re-render with fresh card height
      update();
    }, { passive: true });
  })();
  </script>

  <!-- ── About teaser ───────────────────────────────────────────────────── -->
  <section class="py-28 px-6 border-t border-white/8" aria-labelledby="about-heading">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Left: copy -->
        <div class="flex flex-col gap-6 reveal">
          <span class="eyebrow">Who we are</span>
          <h2 class="heading-1 text-[#F0EFEB]" id="about-heading">
            A real person.<br />Not a call center.
          </h2>
          <p class="text-[#8A8A96] leading-relaxed">
            Giganephew was founded by Aram, a tech professional with over 25 years of experience.
            The idea was simple: most people don't need enterprise IT — they need someone patient,
            knowledgeable, and willing to sit down with them at their kitchen table.
          </p>
          <p class="text-[#8A8A96] leading-relaxed">
            Every visit is one-on-one. No rotating technicians, no scripts. Just straightforward
            help from someone who genuinely enjoys making technology work for people.
          </p>
          <a
            href="/about"
            class="group inline-flex items-center gap-2 text-sm font-semibold text-[#22D3EE]
                   hover:text-[#38bdf8] transition-colors duration-300 w-fit mt-2"
          >
            More about Giganephew
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"
                 class="transition-transform duration-300 group-hover:translate-x-0.5">
              <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Right: accent card -->
        <div class="card-bezel reveal" style="transition-delay: 120ms">
          <div class="card-inner p-8 flex flex-col gap-6">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-[#22D3EE]"
                 style="background: rgba(34,211,238,0.08)">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <blockquote class="text-[#F0EFEB] text-lg font-medium leading-relaxed">
              "Technology should make your life easier — not give you a headache.
              My job is to make that actually true, in your home."
            </blockquote>
            <footer class="flex flex-col gap-0.5">
              <span class="text-sm font-semibold text-[#F0EFEB]">Aram</span>
              <span class="text-xs text-[#8A8A96]">Founder, Giganephew</span>
            </footer>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CTA Banner ────────────────────────────────────────────────────── -->
  <section class="py-28 px-6" aria-labelledby="cta-heading">
    <div class="max-w-6xl mx-auto">
      <div class="card-bezel reveal">
        <div
          class="card-inner px-8 py-16 text-center flex flex-col items-center gap-6 relative overflow-hidden"
          style="background: linear-gradient(135deg, #141418 0%, #1a1a22 100%)"
        >
          <div class="absolute inset-0 pointer-events-none"
               style="background: radial-gradient(ellipse at 50% 100%, rgba(34,211,238,0.08) 0%, transparent 65%)"
               aria-hidden="true"></div>
          <span class="eyebrow relative z-10">Ready to get started?</span>
          <h2 class="heading-1 text-[#F0EFEB] relative z-10 max-w-xl" id="cta-heading">
            Let's fix it — at your place.
          </h2>
          <p class="text-[#8A8A96] max-w-md leading-relaxed relative z-10">
            Tell us what's going on and we'll come to you. Same-week availability in most areas.
          </p>
          <a
            href="/contact"
            class="group relative z-10 inline-flex items-center gap-2 pl-6 pr-2 py-3 rounded-full
                   bg-[#22D3EE] text-[#0C0C0E] font-semibold text-sm
                   transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]
                   hover:bg-[#38bdf8] active:scale-[0.98]
                   shadow-[0_0_32px_rgba(34,211,238,0.25)]"
          >
            Book a visit
            <span class="w-8 h-8 rounded-full bg-black/15 flex items-center justify-center
